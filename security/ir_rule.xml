<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1"> 
        <record id="journal_restricted_access_rule" model="ir.rule">
            <field name="name">Acceso Restringido a Diarios por Equipos Autorizados</field>
            <field name="model_id" ref="account.model_account_journal"/>
            <field name="global" eval="True"/>
            <field name="domain_force">
                ['|', ('authorized_team_ids', '=', False), ('authorized_team_ids', 'in', [user.sale_team_id.id])]
            </field>
        </record>

        <record id="account_move_restricted_access_rule" model="ir.rule">
            <field name="name">Acceso Restringido a Asientos por Equipos Autorizados</field>
            <field name="model_id" ref="account.model_account_move"/>
            <field name="global" eval="True"/>
            <field name="domain_force">
                ['|', ('journal_id.authorized_team_ids', '=', False), ('journal_id.authorized_team_ids', 'in', [user.sale_team_id.id])]
            </field>
        </record>
    </data>
</odoo>