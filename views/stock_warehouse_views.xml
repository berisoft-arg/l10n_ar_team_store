<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_warehouse_form_inherit_branch" model="ir.ui.view">
        <field name="name">stock.warehouse.form.inherit.l10n.ar.team.branch</field>
        <field name="model">stock.warehouse</field>
        <field name="inherit_id" ref="stock.view_warehouse"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='code']" position="after">
                <field name="branch_team_id" options="{'no_create': True, 'no_open': True}"/>
            </xpath>
        </field>
    </record>
</odoo>